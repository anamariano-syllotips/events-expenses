// ═══════════════════════════════════════════════════════════
//  Helpers
// ═══════════════════════════════════════════════════════════
const PALETTE = [
  '#4a6cf7','#f7934a','#22c98a','#f74a6c',
  '#a34af7','#f7c94a','#4acff7','#f74af0',
  '#7af74a','#f7514a'
];
const _eventColorMap = {};
function colorFor(ev) {
  if (!_eventColorMap[ev]) {
    _eventColorMap[ev] = PALETTE[Object.keys(_eventColorMap).length % PALETTE.length];
  }
  return _eventColorMap[ev];
}

function statusBadge(s) {
  if (!s || s === '—') return '<span style="color:#ccc">—</span>';
  const isPaid = s === 'Paid';
  const color  = isPaid ? '#22c98a' : '#f7934a';
  const icon   = isPaid ? '✓' : '⏳';
  return `<span style="display:inline-flex;align-items:center;gap:4px;background:${color}18;color:${color};border:1px solid ${color}55;border-radius:5px;padding:2px 8px;font-size:11px;font-weight:700;white-space:nowrap">${icon} ${s}</span>`;
}

const PAYMENT_COLORS = {
  'Card':         '#4a6cf7',
  'Bank Transfer':'#22c98a',
  'Cash':         '#f7934a',
  'Reimbursement':'#a34af7',
};
function paymentBadge(method) {
  if (!method || method === '—') return '<span style="color:#ccc">—</span>';
  const color = PAYMENT_COLORS[method] || '#888';
  return `<span style="display:inline-block;background:${color}18;color:${color};border:1px solid ${color}44;border-radius:5px;padding:2px 8px;font-size:11px;font-weight:600;white-space:nowrap">${method}</span>`;
}

const CURRENCY_SYMBOLS = { EUR: '€', USD: '$', GBP: '£', CHF: 'CHF ' };
function fmt(n, currency) {
  const sym = CURRENCY_SYMBOLS[currency] || (currency ? currency + ' ' : '$');
  const locale = (currency === 'EUR') ? 'it-IT' : 'en-US';
  return sym + Number(n).toLocaleString(locale, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}
// Group totals by currency
function totalsByCurrency(list) {
  const map = {};
  list.forEach(e => { const c = e.currency || 'USD'; map[c] = (map[c]||0) + e.amount; });
  return map;
}
function fmtTotals(map) {
  return Object.entries(map).map(([c,v]) => fmt(v, c)).join(' + ') || '—';
}
function monthKey(d)   { return d.slice(0, 7); }
function monthLabel(k) {
  const [y, m] = k.split('-');
  return new Date(+y, +m - 1, 1).toLocaleString('en', { month: 'long', year: 'numeric' });
}

// ═══════════════════════════════════════════════════════════
//  Cards
// ═══════════════════════════════════════════════════════════
function updateCards() {
  const events   = [...new Set(EXPENSES.map(e => e.event || 'General'))];
  const now      = new Date();
  const curKey   = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`;
  const thisMonthExp = EXPENSES.filter(e => monthKey(e.date) === curKey);

  // Top event by amount (same currency grouping)
  const byEvent  = {};
  EXPENSES.forEach(e => { const k = e.event || 'General'; byEvent[k] = (byEvent[k]||0) + e.amount; });
  const top = Object.entries(byEvent).sort((a,b) => b[1]-a[1])[0];

  document.getElementById('c-total').textContent    = fmtTotals(totalsByCurrency(EXPENSES));
  document.getElementById('c-invoices').textContent = EXPENSES.length + ' invoice' + (EXPENSES.length !== 1 ? 's' : '');
  document.getElementById('c-events').textContent   = events.length;
  document.getElementById('c-month').textContent    = thisMonthExp.length ? fmtTotals(totalsByCurrency(thisMonthExp)) : '—';
  document.getElementById('c-month-label').textContent = now.toLocaleString('en', { month: 'long', year: 'numeric' });
  document.getElementById('c-top-val').textContent  = top ? fmtTotals(totalsByCurrency(EXPENSES.filter(e=>(e.event||'General')===top[0]))) : '—';
  document.getElementById('c-top-name').textContent = top ? top[0] : '—';

  const pendingExp = EXPENSES.filter(e => e.status === 'Pending');
  document.getElementById('c-pending').textContent       = pendingExp.length ? fmtTotals(totalsByCurrency(pendingExp)) : '—';
  document.getElementById('c-pending-count').textContent = pendingExp.length + ' invoice' + (pendingExp.length !== 1 ? 's' : '') + ' to pay';
}

// ═══════════════════════════════════════════════════════════
//  All Expenses tab (Grid.js)
// ═══════════════════════════════════════════════════════════
let _grid = null;
function renderGrid() {
  const container = document.getElementById('grid-container');
  if (_grid) { try { _grid.destroy(); } catch(e){} _grid = null; }
  container.innerHTML = '';

  if (EXPENSES.length === 0) {
    container.innerHTML = `
      <div class="empty-state">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5">
          <rect x="3" y="4" width="18" height="16" rx="2"/>
          <path d="M3 9h18M8 4v5M16 4v5"/>
        </svg>
        <strong>No expenses yet</strong>
        <span>Upload invoices to Claude or click "+ Add Expense" to get started.</span>
      </div>`;
    return;
  }

  const rows = [...EXPENSES]
    .sort((a,b) => b.date.localeCompare(a.date))
    .map(e => [
      e.date,
      e.event          || '—',
      e.issuer,
      e.category       || '—',
      e.invoiceNo      || '—',
      e.status         || '—',
      e.paymentMethod  || '—',
      e.notes          || '—',
      e.currency       || 'USD',
      e.amount,
      e.id,   // index 10 — used by status toggle and edit button
    ]);

  _grid = new gridjs.Grid({
    columns: [
      { name: 'Date',            width: '100px' },
      { name: 'Event',           width: '160px' },
      { name: 'Invoice Issuer' },
      { name: 'Category',        width: '125px' },
      { name: 'Invoice #',       width: '110px' },
      {
        name: 'Status', width: '108px',
        formatter: (cell, row) => gridjs.html(
          `<span class="status-toggle" title="Click to toggle" onclick="toggleStatus(${row.cells[10].data})">${statusBadge(cell)}</span>`
        )
      },
      { name: 'Payment',  width: '110px', formatter: (cell) => gridjs.html(paymentBadge(cell)) },
      { name: 'Notes' },
      { name: 'CCY',      width: '54px'  },
      {
        name: 'Amount', width: '118px',
        formatter: (cell, row) => gridjs.html(`<span class="amount-cell">${fmt(cell, row.cells[8].data)}</span>`)
      },
      {
        id: 'edit-col', name: '', width: '48px', sort: false,
        formatter: (cell) => gridjs.html(`<button class="edit-btn" title="Edit" onclick="openEditModal(${cell})">✏️</button>`)
      },
    ],
    data: rows,
    search: true,
    sort:   true,
    pagination: { limit: 15, summary: false },
  }).render(container);
}

// ═══════════════════════════════════════════════════════════
//  By Month tab
// ═══════════════════════════════════════════════════════════
let _monthChart = null;
function renderMonthTab() {
  const byMonth = {};
  EXPENSES.forEach(e => { const k = monthKey(e.date); byMonth[k] = (byMonth[k]||0) + e.amount; });
  const keys   = Object.keys(byMonth).sort();
  const labels = keys.map(k => monthLabel(k));
  const values = keys.map(k => byMonth[k]);
  const total  = values.reduce((a,b) => a+b, 0);

  const ctx = document.getElementById('monthChart').getContext('2d');
  if (_monthChart) { _monthChart.destroy(); _monthChart = null; }

  if (keys.length === 0) {
    document.getElementById('month-table-container').innerHTML =
      '<p style="color:#bbb;font-size:13px;padding:20px 0;">No data yet.</p>';
    return;
  }

  _monthChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        label: 'Expenses',
        data: values,
        backgroundColor: '#4a6cf7',
        borderRadius: 7,
        borderSkipped: false,
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: c => ' ' + c.parsed.y.toLocaleString() } } },
      scales: {
        y: { beginAtZero: true, ticks: { callback: v => v.toLocaleString() }, grid: { color: '#f0f0f0' } },
        x: { grid: { display: false } }
      }
    }
  });

  const tableRows = keys.map((k, i) => {
    const monthExp = EXPENSES.filter(e => monthKey(e.date) === k);
    const totStr = fmtTotals(totalsByCurrency(monthExp));
    return `<tr>
      <td>${labels[i]}</td>
      <td class="amount-cell" style="text-align:right">${totStr}</td>
      <td class="pct-cell">${total > 0 ? Math.round(values[i]/total*100) : 0}%</td>
    </tr>`;
  }).join('');

  document.getElementById('month-table-container').innerHTML = `
    <table class="summary-table">
      <thead><tr><th>Month</th><th style="text-align:right">Amount</th><th style="text-align:right">Share</th></tr></thead>
      <tbody>${tableRows}</tbody>
      <tfoot><tr><td>Total</td><td class="amount-cell" style="text-align:right">${fmtTotals(totalsByCurrency(EXPENSES))}</td><td class="pct-cell">100%</td></tr></tfoot>
    </table>`;
}

// ═══════════════════════════════════════════════════════════
//  By Event tab
// ═══════════════════════════════════════════════════════════
let _eventChart = null;
function renderEventTab() {
  const byEvent = {};
  EXPENSES.forEach(e => { const k = e.event || 'General'; byEvent[k] = (byEvent[k]||0) + e.amount; });
  const sorted = Object.entries(byEvent).sort((a,b) => b[1]-a[1]);
  const labels = sorted.map(([k]) => k);
  const values = sorted.map(([,v]) => v);
  const colors = labels.map(l => colorFor(l));
  const total  = values.reduce((a,b) => a+b, 0);

  const ctx = document.getElementById('eventChart').getContext('2d');
  if (_eventChart) { _eventChart.destroy(); _eventChart = null; }

  if (sorted.length === 0) {
    document.getElementById('event-table-container').innerHTML =
      '<p style="color:#bbb;font-size:13px;padding:20px 0;">No data yet.</p>';
    return;
  }

  _eventChart = new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels,
      datasets: [{ data: values, backgroundColor: colors, borderWidth: 2, borderColor: '#fff' }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { position: 'bottom', labels: { font: { size: 11 }, padding: 12, usePointStyle: true } },
        tooltip: { callbacks: { label: c => ' ' + fmt(c.parsed) + '  (' + Math.round(c.parsed/total*100) + '%)' } }
      }
    }
  });

  const eventRows = sorted.map(([name, val], i) => {
    const evExp = EXPENSES.filter(e => (e.event || 'General') === name);
    const totStr = fmtTotals(totalsByCurrency(evExp));
    return `<tr>
      <td><span class="dot" style="background:${colors[i]}"></span>${name}</td>
      <td class="amount-cell" style="text-align:right">${totStr}</td>
      <td class="pct-cell">${total > 0 ? Math.round(val/total*100) : 0}%</td>
    </tr>`;
  }).join('');

  document.getElementById('event-table-container').innerHTML = `
    <table class="summary-table">
      <thead><tr><th>Event</th><th style="text-align:right">Amount</th><th style="text-align:right">Share</th></tr></thead>
      <tbody>${eventRows}</tbody>
      <tfoot><tr><td>Total</td><td class="amount-cell" style="text-align:right">${fmtTotals(totalsByCurrency(EXPENSES))}</td><td class="pct-cell">100%</td></tr></tfoot>
    </table>`;
}

// ═══════════════════════════════════════════════════════════
//  Tab switching
// ═══════════════════════════════════════════════════════════
function switchTab(name, btn) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('tab-' + name).classList.add('active');
  if (name === 'month') renderMonthTab();
  if (name === 'event') renderEventTab();
}

// ═══════════════════════════════════════════════════════════
//  Status toggle (click badge in table)
// ═══════════════════════════════════════════════════════════
function toggleStatus(id) {
  const entry = EXPENSES.find(e => e.id === id);
  if (!entry) return;
  entry.status = entry.status === 'Paid' ? 'Pending' : 'Paid';
  refresh();
}

// ═══════════════════════════════════════════════════════════
//  Modal — Add & Edit
// ═══════════════════════════════════════════════════════════
function _populateEventList() {
  const evList = document.getElementById('event-list');
  evList.innerHTML = '';
  [...new Set(EXPENSES.map(e => e.event).filter(Boolean))].forEach(ev => {
    const o = document.createElement('option'); o.value = ev; evList.appendChild(o);
  });
}

function _setSelect(id, val) {
  const el = document.getElementById(id);
  for (let opt of el.options) { if (opt.value === val) { el.value = val; return; } }
}

function openModal() {
  _populateEventList();
  document.getElementById('modal-title').textContent = 'Add Expense';
  document.getElementById('f-edit-id').value = '';
  document.getElementById('f-date').value    = new Date().toISOString().slice(0,10);
  ['f-amount','f-event','f-issuer','f-category','f-invoice-no','f-notes']
    .forEach(id => document.getElementById(id).value = '');
  _setSelect('f-currency', 'USD');
  _setSelect('f-payment',  'Card');
  _setSelect('f-status',   'Paid');
  document.getElementById('modal').classList.add('open');
}

function openEditModal(id) {
  const e = EXPENSES.find(x => x.id === id);
  if (!e) return;
  _populateEventList();
  document.getElementById('modal-title').textContent  = 'Edit Expense';
  document.getElementById('f-edit-id').value          = e.id;
  document.getElementById('f-date').value             = e.date;
  document.getElementById('f-amount').value           = e.amount;
  document.getElementById('f-event').value            = e.event    || '';
  document.getElementById('f-issuer').value           = e.issuer   || '';
  document.getElementById('f-category').value         = e.category || '';
  document.getElementById('f-invoice-no').value       = e.invoiceNo|| '';
  document.getElementById('f-notes').value            = e.notes    || '';
  _setSelect('f-currency', e.currency      || 'USD');
  _setSelect('f-payment',  e.paymentMethod || 'Card');
  _setSelect('f-status',   e.status        || 'Paid');
  document.getElementById('modal').classList.add('open');
}

function closeModal() { document.getElementById('modal').classList.remove('open'); }
function onOverlayClick(e) { if (e.target === document.getElementById('modal')) closeModal(); }

function submitExpense() {
  const date          = document.getElementById('f-date').value;
  const amount        = parseFloat(document.getElementById('f-amount').value);
  const currency      = document.getElementById('f-currency').value;
  const paymentMethod = document.getElementById('f-payment').value;
  const status        = document.getElementById('f-status').value;
  const event         = document.getElementById('f-event').value.trim();
  const issuer        = document.getElementById('f-issuer').value.trim();
  const category      = document.getElementById('f-category').value.trim();
  const invoiceNo     = document.getElementById('f-invoice-no').value.trim();
  const notes         = document.getElementById('f-notes').value.trim();
  const editId        = document.getElementById('f-edit-id').value;

  if (!date || isNaN(amount) || !issuer) {
    alert('Please fill in Date, Amount, and Invoice Issuer.');
    return;
  }

  if (editId) {
    // Update existing entry
    const idx = EXPENSES.findIndex(e => e.id === Number(editId));
    if (idx !== -1) {
      EXPENSES[idx] = { ...EXPENSES[idx], date, event, amount, currency, issuer, category, invoiceNo, paymentMethod, status, notes };
    }
  } else {
    // Add new entry
    EXPENSES.push({ id: Date.now(), date, event, amount, currency, issuer, category, invoiceNo, paymentMethod, status, notes });
  }

  closeModal();
  refresh();
}

// ═══════════════════════════════════════════════════════════
//  Full refresh
// ═══════════════════════════════════════════════════════════
function refresh() {
  updateCards();
  renderGrid();
  // Refresh whichever tab is visible
  if (document.getElementById('tab-month').classList.contains('active')) renderMonthTab();
  if (document.getElementById('tab-event').classList.contains('active')) renderEventTab();
}

// ── Init ──────────────────────────────────────────────────
refresh();
</script>

